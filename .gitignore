# Environment variables — never commit
.env
.env.local
.env.production

# Firebase project config — local only
.firebaserc

# Firebase service account — never commit
serviceAccountKey.json
*serviceAccount*.json

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Functions
functions/node_modules/
functions/lib/

# Python seed scripts
__pycache__/
*.pyc
scripts/.venv/

# Firebase debug logs
firebase-debug.log
firestore-debug.log
ui-debug.log

# macOS
.DS_Store

# IDE
.vscode/
.idea/

# Word docs
*.docx
